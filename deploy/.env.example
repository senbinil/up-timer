# ============================================
# UpTimer Deployment — Environment Variables
# ============================================
# Generated by: ./deploy/installer.sh
# Or copy this file to deploy/.env and fill in manually.
#
# Only fill in variables relevant to your deployment mode.
# See deploy/README.md for full documentation.

# ── App ─────────────────────────────────────
# Docker image tag (default: latest)
TAG=latest

# Rails secret key base (optional — auto-generated if empty)
SECRET_KEY_BASE=

# Comma-separated admin emails (auto-assigns admin role on registration)
# Example: admin@example.com,manager@example.com
ADMIN_EMAILS=

# Host used for links in emails (falls back to DOMAIN if unset)
APP_HOST=

# Puma / Solid Queue thread pool size (default: 3, auto-detected range: 3–16)
RAILS_MAX_THREADS=3

# Set to "true" to run Solid Queue inside Puma (required for single-container)
SOLID_QUEUE_IN_PUMA=true

# ── Database ────────────────────────────────
# Provider: sqlite (default) or postgres
DB_PROVIDER=sqlite

# PostgreSQL (only needed if DB_PROVIDER=postgres)
# DATABASE_URL is auto-constructed by the PG compose override, or set manually:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Email (optional) ────────────────────────
# Provider: resend or mailgun. Leave empty to disable email delivery.
MAIL_PROVIDER=
MAIL_FROM=noreply@example.com

# Resend (only needed if MAIL_PROVIDER=resend)
RESEND_API_KEY=

# Mailgun (only needed if MAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Domain ──────────────────────────────────
# Public domain for your UpTimer instance (REQUIRED for proxy modes)
DOMAIN=

# ── Standalone Traefik ──────────────────────
# Let's Encrypt notification email (REQUIRED for standalone Traefik)
LETSENCRYPT_EMAIL=

# DNS provider for Let's Encrypt DNS-01 challenge
# Supported: cloudflare, acmedns, ... (see https://doc.traefik.io/traefik/https/acme/#dnschallenge)
DNS_PROVIDER=cloudflare

# Cloudflare API token with DNS:Edit permission (REQUIRED for standalone Traefik)
CF_DNS_API_TOKEN=

# ── Existing Traefik ────────────────────────
# External Docker network name (auto-detected by installer)
# Common values: kamal, traefik-public
TRAEFIK_NETWORK=

# Traefik entrypoint: web (HTTP only) or websecure (HTTPS). Default: websecure
ENTRYPOINT=

# ── Cloudflare Tunnel ───────────────────────
# Tunnel token from Cloudflare Zero Trust dashboard
# Dashboard → Networks → Tunnels → Create a tunnel → Docker
CF_TUNNEL_TOKEN=

# ── IP-only ─────────────────────────────────
# Host port to bind (default: 80)
APP_PORT=80
