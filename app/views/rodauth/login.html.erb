<div class="w-full max-w-md space-y-6">
  <%# ── Section Header ── %>
  <div class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Authentication</p>
    <h1 class="text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk]">Log In</h1>
    <p class="text-body-lg text-slate-400">Access your secure infrastructure dashboard.</p>
  </div>

  <%# ── Login Card ── %>
  <div class="card space-y-6">
    <%== rodauth.login_form_header %>
    <%= render "login_form" %>
    <%== rodauth.login_form_footer %>
  </div>

  <%# ── Sub-Card Navigation ── %>
  <p class="text-center text-sm text-slate-400">
    Don't have an account?
    <%= link_to "Create Account", rodauth.create_account_path, class: "text-primary-container hover:underline font-medium" %>
  </p>
</div>
