<div class="w-full max-w-md space-y-6">
  <%# ── Section Header ── %>
  <div class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Registration</p>
    <h1 class="text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk]">Create Account</h1>
    <p class="text-body-lg text-slate-400">Register a new user account to the secure infrastructure cluster.</p>
  </div>

  <%# ── Registration Card ── %>
  <div class="card">
    <%= form_with url: rodauth.create_account_path, method: :post, data: { turbo: false }, class: "space-y-8" do |form| %>
      <%# ── Email Field ── %>
      <div class="space-y-1.5">
        <%= form.label rodauth.login_param, "Username", class: "input-label block" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </span>
          <span class="absolute -top-2 -right-1 text-xs text-slate-400 bg-surface px-1 rounded font-mono">&gt;_</span>
          <%= form.email_field rodauth.login_param, value: params[rodauth.login_param], id: "login", autocomplete: "email", required: true, placeholder: "sys_admin_alpha", class: "input-field pl-10 #{rodauth.field_error(rodauth.login_param) ? "!border-error" : ""}" %>
        </div>
        <%= content_tag(:p, rodauth.field_error(rodauth.login_param), class: "text-xs text-error font-mono mt-1") if rodauth.field_error(rodauth.login_param) %>
      </div>

      <%# ── Name Field ── %>
      <div class="space-y-1.5">
        <%= form.label "name", "Name", class: "input-label block" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
            </svg>
          </span>
          <%= form.text_field "name", value: params["name"], id: "name", required: true, placeholder: "Johnathan Doe", class: "input-field pl-10 #{rodauth.field_error("name") ? "!border-error" : ""}" %>
        </div>
        <%= content_tag(:p, rodauth.field_error("name"), class: "text-xs text-error font-mono mt-1") if rodauth.field_error("name") %>
      </div>

      <%# ── Password Field ── %>
      <div class="space-y-1.5">
        <%= form.label rodauth.password_param, "Password", class: "input-label block" %>
        <div class="relative" data-controller="password-toggle">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </span>
          <%= form.password_field rodauth.password_param, value: "", id: "password", autocomplete: rodauth.password_field_autocomplete_value, required: true, class: "input-field pl-10 pr-10 #{rodauth.field_error(rodauth.password_param) ? "!border-error" : ""}", data: { password_toggle_target: "input" } %>
          <button type="button" data-action="password-toggle#toggle" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-navy transition-colors cursor-pointer">
            <%# Eye open icon %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-password-toggle-target="icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <%# Eye off icon (hidden by default) %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-password-toggle-target="icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </button>
        </div>
        <%= content_tag(:p, rodauth.field_error(rodauth.password_param), class: "text-xs text-error font-mono mt-1") if rodauth.field_error(rodauth.password_param) %>
      </div>

      <%# ── Confirm Password Field ── %>
      <% if rodauth.require_password_confirmation? %>
        <div class="space-y-1.5">
          <%= form.label rodauth.password_confirm_param, rodauth.password_confirm_label, class: "input-label block" %>
          <div class="relative" data-controller="password-toggle">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
              </svg>
            </span>
            <%= form.password_field rodauth.password_confirm_param, value: "", id: "password-confirm", autocomplete: "new-password", required: true, class: "input-field pl-10 pr-10 #{rodauth.field_error(rodauth.password_confirm_param) ? "!border-error" : ""}", data: { password_toggle_target: "input" } %>
            <button type="button" data-action="password-toggle#toggle" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-navy transition-colors cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-password-toggle-target="icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-password-toggle-target="icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
              </svg>
            </button>
          </div>
          <%= content_tag(:p, rodauth.field_error(rodauth.password_confirm_param), class: "text-xs text-error font-mono mt-1") if rodauth.field_error(rodauth.password_confirm_param) %>
        </div>
      <% end %>

      <%# ── Compliance Checkbox ── %>
      <div class="flex items-start gap-3">
        <input type="checkbox" name="compliance" id="compliance" class="mt-0.5 h-4 w-4 rounded border border-[#e2e8f0] text-primary-container focus:ring-primary-container #{rodauth.field_error("compliance") ? "!border-error" : ""}" />
        <label for="compliance" class="text-xs text-slate-400 leading-5">I agree to the terms of service and privacy policy.</label>
      </div>
      <%= content_tag(:p, rodauth.field_error("compliance"), class: "text-xs text-error font-mono mt-1 ml-7") if rodauth.field_error("compliance") %>

      <%# ── Submit Button ── %>
      <%= form.button class: "btn btn-primary w-full justify-center", name: "commit" do %>
        Sign Up &rarr;
      <% end %>
    <% end %>
  </div>

  <%# ── Sub-Card Navigation ── %>
  <p class="text-center text-sm text-slate-400">
    Already have an account?
    <%= link_to "Log In", rodauth.login_path, class: "text-primary-container hover:underline font-medium" %>
  </p>
</div>
