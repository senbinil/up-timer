<div class="w-full max-w-md space-y-6">
  <div class="space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Verification</p>
    <h1 class="text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk]">Resend Verification</h1>
    <p class="text-body-lg text-slate-400">Enter your email to receive a new verification link.</p>
  </div>

  <div class="card">
    <%= form_with url: rodauth.verify_account_resend_path, method: :post, data: { turbo: false }, class: "space-y-8" do |form| %>
      <% if params[rodauth.login_param] %>
        <%= form.hidden_field rodauth.login_param, value: params[rodauth.login_param] %>
      <% else %>
        <div class="space-y-1.5">
          <%= form.label "login", "Email", class: "input-label block" %>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </span>
            <%= form.email_field rodauth.login_param, value: params[rodauth.login_param], id: "login", autocomplete: "email", required: true, class: "input-field pl-10 #{rodauth.field_error(rodauth.login_param) ? "!border-error" : ""}", aria: ({ invalid: true, describedby: "login_error_message" } if rodauth.field_error(rodauth.login_param)) %>
          </div>
          <%= content_tag(:p, rodauth.field_error(rodauth.login_param), class: "text-xs text-error font-mono mt-1", id: "login_error_message") if rodauth.field_error(rodauth.login_param) %>
        </div>
      <% end %>

      <%= form.button rodauth.verify_account_resend_button, class: "btn btn-primary w-full justify-center" %>
    <% end %>
  </div>

  <p class="text-center text-sm text-slate-400">
    <%= link_to "Back to Log In", rodauth.login_path, class: "text-primary-container hover:underline font-medium" %>
  </p>
</div>
