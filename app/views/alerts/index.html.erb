<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-navy font-[Hanken_Grotesk]">Alerts</h1>
      <p class="text-xs text-slate-400 font-mono mt-1">Monitor system events and incidents</p>
    </div>
    <% if current_account&.collaborator? %>
    <%= link_to new_alert_path, class: "btn btn-primary text-xs py-1.5 px-3" do %>
      New Alert &plus;
    <% end %>
    <% end %>
  </div>

  <div class="card space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Last 30 Days</p>
    <div class="flex gap-1 flex-wrap">
      <% @heatmap.each do |day| %>
        <% bg = if day[:critical] > 0
                 "bg-error"
               elsif day[:warning] > 0
                 "bg-warning"
               elsif day[:info] > 0
                 "bg-primary-container/60"
               else
                 "bg-surface-container-high"
               end %>
        <div class="w-3.5 h-3.5 rounded-sm <%= bg %>" data-controller="tooltip" data-tooltip-content-value="<%= day[:date].strftime('%b %d') %>: <%= day[:critical] %> crit, <%= day[:warning] %> warn, <%= day[:info] %> info"></div>
      <% end %>
    </div>
    <div class="flex items-center gap-3 text-[10px] text-slate-400 font-mono pt-1">
      <span>Less</span>
      <span class="w-3 h-3 rounded-sm bg-surface-container-high"></span>
      <span class="w-3 h-3 rounded-sm bg-primary-container/60"></span>
      <span class="w-3 h-3 rounded-sm bg-warning"></span>
      <span class="w-3 h-3 rounded-sm bg-error"></span>
      <span>More</span>
    </div>
  </div>

  <% if @alerts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @alerts.each do |alert| %>
        <%= link_to alert_path(alert), class: "card space-y-4 block hover:border-primary-container/30 transition-colors group" do %>
          <div class="flex items-start justify-between">
            <span class="<%= severity_chip_class(alert.severity) %> text-[10px]"><%= alert.severity %></span>
            <% if alert.resolved? %>
              <span class="chip chip-success text-[10px]">Resolved</span>
            <% else %>
              <span class="w-2 h-2 rounded-full <%= alert.severity == 'critical' ? 'bg-error animate-pulse' : 'bg-warning' %> flex-shrink-0" title="Active"></span>
            <% end %>
          </div>

          <div class="flex-1">
            <p class="text-sm font-medium text-navy leading-snug line-clamp-2 group-hover:text-primary-container transition-colors"><%= alert.message %></p>
          </div>

          <div class="flex items-center justify-between pt-2 border-t border-divider">
            <div class="flex items-center gap-1.5">
              <%= lucide_icon "server", size: 12, class: "text-slate-400" %>
              <span class="text-[11px] text-slate-400 font-mono"><%= alert.monitor&.name || "System" %></span>
            </div>
            <span class="text-[10px] text-slate-400 font-mono"><%= time_ago_in_words(alert.created_at) %> ago</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-16 space-y-3">
      <%= lucide_icon "bell-off", size: 32, class: "text-slate-300 mx-auto" %>
      <div>
        <p class="text-body-lg text-navy font-medium">No alerts yet</p>
        <p class="text-xs text-slate-400 mt-1">Create your first alert to start tracking system events.</p>
      </div>
    </div>
  <% end %>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center pt-4">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
