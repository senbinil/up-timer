<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-navy font-[Hanken_Grotesk]">Alerts</h1>
    <%= link_to "New Alert +", new_alert_path, class: "btn btn-primary text-xs py-1.5 px-3" %>
  </div>

  <% if @alerts.any? %>
    <div class="card space-y-0">
      <div class="hidden md:grid grid-cols-[80px_100px_1fr_120px_80px] gap-4 px-1 py-3 text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono border-b border-divider">
        <span>Severity</span>
        <span>Node</span>
        <span>Message</span>
        <span>Time</span>
        <span></span>
      </div>
      <% @alerts.each do |alert| %>
        <div class="md:grid md:grid-cols-[80px_100px_1fr_120px_80px] gap-4 px-1 py-3 items-center list-row">
          <span class="<%= severity_chip_class(alert.severity) %> text-[10px]"><%= alert.severity %></span>
          <span class="text-xs text-slate-400 font-mono"><%= alert.monitor&.name || "-" %></span>
          <span class="text-xs text-slate-400 truncate"><%= alert.message %></span>
          <span class="text-[10px] text-slate-400 font-mono"><%= time_ago_in_words(alert.created_at) %> ago</span>
          <div class="flex items-center gap-2">
            <%= link_to "View", alert_path(alert), class: "text-[10px] text-primary-container hover:underline" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12 text-slate-400">
      <p class="text-body-lg">No alerts.</p>
      <p class="text-xs mt-1">Create an alert to start tracking.</p>
    </div>
  <% end %>
</div>
