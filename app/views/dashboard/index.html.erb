<%= turbo_stream_from "dashboard" %>

<div class="space-y-6">
  <%# ═══════════════════════════════════════════════
     Row 1: Global Fleet Status (Full Width)
     ═══════════════════════════════════════════════ %>
  <%= render "dashboard/fleet_status", stats: @stats, alert_counts: @alert_counts, nodes: @nodes %>

  <%# ═══════════════════════════════════════════════
     Row 2: Active Services (3-Column)
     ═══════════════════════════════════════════════ %>
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-navy font-[Hanken_Grotesk]">Active Services</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @services.each do |node| %>
        <%= render "nodes/node_card", node: node %>
      <% end %>
    </div>
  </div>

  <%# ═══════════════════════════════════════════════
     Alert Activity Chart
     ═══════════════════════════════════════════════ %>
  <div class="card space-y-3">
    <p class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Alert Activity — Last 15 Days</p>
    <%= area_chart alert_chart_data(@heatmap),
                   discrete: true,
                   stacked: true,
                   height: "240px",
                   library: {
                     scales: {
                       x: { type: "category", grid: { display: false } },
                       y: { beginAtZero: true, ticks: { stepSize: 1 } }
                     },
                     plugins: { legend: { position: "bottom", labels: { boxWidth: 12, padding: 16 } } }
                   } %>
  </div>

  <%# ═══════════════════════════════════════════════
     Row 3: Recent Alerts Table
     ═══════════════════════════════════════════════ %>
  <div class="card space-y-0">
    <div class="flex items-center justify-between pb-3 border-b border-divider">
      <h2 class="text-base font-semibold text-navy font-[Hanken_Grotesk]">Recent Alerts</h2>
      <%= link_to "View All", alerts_path, class: "text-xs text-primary-container hover:underline font-medium" %>
    </div>

    <div id="recent_alerts">
      <% if @alerts.any? %>
        <% @alerts.each do |alert| %>
          <%= render "alerts/alert_row", alert: alert %>
        <% end %>
      <% else %>
        <div class="py-8 text-center text-xs text-slate-400">No alerts yet.</div>
      <% end %>
    </div>
  </div>
</div>
