<div class="space-y-6">
  <%# ═══════════════════════════════════════════════
     Row 1: Status Cards (2-Column)
     ═══════════════════════════════════════════════ %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# ── Card 1.1: Global Fleet Status (2/3 width) ── %>
    <div class="card lg:col-span-2 space-y-5">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-primary-container"></span>
        <span class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Global Fleet Status</span>
      </div>

      <div>
        <h2 class="text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk]">Operational</h2>
        <p class="text-body-md text-slate-400 mt-1">All core systems are functioning within normal parameters. Last deployment completed successfully 4 hours ago.</p>
      </div>

      <div class="grid grid-cols-3 gap-4 pt-4 border-t border-divider">
        <div>
          <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Uptime</p>
          <p class="text-2xl font-semibold text-navy font-[Hanken_Grotesk] mt-1">99.98%</p>
        </div>
        <div>
          <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Active Nodes</p>
          <p class="text-2xl font-semibold text-navy font-[Hanken_Grotesk] mt-1">1,402</p>
        </div>
        <div>
          <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Error Rate</p>
          <p class="text-2xl font-semibold text-navy font-[Hanken_Grotesk] mt-1">0.02%</p>
        </div>
      </div>
    </div>

    <%# ── Card 1.2: System Load (1/3 width) ── %>
    <div class="card space-y-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">System Load</span>
        </div>
        <span class="chip chip-success text-[10px]">Live</span>
      </div>

      <%# CPU %>
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="font-mono text-slate-400">CPU Usage</span>
          <span class="font-mono font-semibold text-navy">42%</span>
        </div>
        <div class="h-2 bg-surface-container-low rounded-full overflow-hidden">
          <div class="h-full w-[42%] bg-primary-container rounded-full"></div>
        </div>
      </div>

      <%# Memory %>
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="font-mono text-slate-400">Memory Alloc</span>
          <span class="font-mono font-semibold text-navy">68%</span>
        </div>
        <div class="h-2 bg-surface-container-low rounded-full overflow-hidden">
          <div class="h-full w-[68%] bg-navy rounded-full"></div>
        </div>
      </div>

      <%# Network %>
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="font-mono text-slate-400">Network I/O</span>
          <span class="font-mono font-semibold text-navy">812 Mbps</span>
        </div>
        <div class="h-2 bg-surface-container-low rounded-full overflow-hidden">
          <div class="h-full w-[55%] bg-primary-container rounded-full"></div>
        </div>
      </div>
    </div>
  </div>

  <%# ═══════════════════════════════════════════════
     Row 2: Active Services (3-Column)
     ═══════════════════════════════════════════════ %>
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-navy font-[Hanken_Grotesk]">Active Services</h2>
      <div class="flex items-center gap-4 text-xs text-slate-400 font-mono">
        <span class="cursor-pointer hover:text-navy">Filter</span>
        <span class="cursor-pointer hover:text-navy">Sort &#9776;</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%# ── Card 2.1: API Gateway ── %>
      <div class="card space-y-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-default bg-primary-container/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-container" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-navy">API Gateway</h3>
              <p class="text-[11px] text-slate-400 font-mono">us-east-1</p>
            </div>
          </div>
          <span class="w-2 h-2 rounded-full bg-primary-container flex-shrink-0 mt-1.5"></span>
        </div>

        <div class="space-y-2 pt-2 border-t border-divider">
          <div class="flex justify-between text-xs">
            <span class="font-mono text-slate-400">Latency</span>
            <span class="font-mono font-semibold text-navy">42ms</span>
          </div>
          <div class="flex justify-between text-xs">
            <span class="font-mono text-slate-400">Throughput</span>
            <span class="font-mono font-semibold text-navy">12.4k req/s</span>
          </div>
        </div>

        <div class="pt-2 border-t border-divider">
          <div class="flex justify-between text-xs mb-2">
            <span class="font-mono text-slate-400">30 Days</span>
            <span class="font-mono font-semibold text-primary-container">100%</span>
          </div>
          <div class="flex items-end gap-[2px] h-10">
            <% 24.times do %>
              <div class="flex-1 bg-primary-container/70 rounded-sm" style="height: <%= rand(40..100) %>%"></div>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Card 2.2: Primary DB ── %>
      <div class="card space-y-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-default bg-error-container/50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125v-3.75" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-navy">Primary DB</h3>
              <p class="text-[11px] text-slate-400 font-mono">us-west-2</p>
            </div>
          </div>
          <span class="w-2 h-2 rounded-full bg-error flex-shrink-0 mt-1.5"></span>
        </div>

        <div class="space-y-2 pt-2 border-t border-divider">
          <div class="flex justify-between text-xs">
            <span class="font-mono text-slate-400">Connections</span>
            <span class="font-mono font-semibold text-error">4,902 / 5,000</span>
          </div>
          <div class="flex justify-between text-xs">
            <span class="font-mono text-slate-400">Replica Lag</span>
            <span class="font-mono font-semibold text-navy">1.2s</span>
          </div>
        </div>

        <div class="pt-2 border-t border-divider">
          <div class="flex justify-between text-xs mb-2">
            <span class="font-mono text-slate-400">30 Days</span>
            <span class="font-mono font-semibold text-error">98.2%</span>
          </div>
          <div class="flex items-end gap-[2px] h-10">
            <% 24.times do |i| %>
              <div class="flex-1 rounded-sm <%= [20, 15].include?(i) ? 'bg-error' : 'bg-primary-container/70' %>" style="height: <%= [20, 15].include?(i) ? rand(30..50) : rand(60..100) %>%"></div>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Card 2.3: Authentication ── %>
      <div class="card space-y-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-default bg-primary-container/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-container" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-navy">Authentication</h3>
              <p class="text-[11px] text-slate-400 font-mono">global</p>
            </div>
          </div>
          <span class="w-2 h-2 rounded-full bg-primary-container flex-shrink-0 mt-1.5"></span>
        </div>

        <div class="space-y-2 pt-2 border-t border-divider">
          <div class="flex justify-between text-xs">
            <span class="font-mono text-slate-400">Auth Rate</span>
            <span class="font-mono font-semibold text-navy">2.1k / min</span>
          </div>
          <div class="flex justify-between text-xs">
            <span class="font-mono text-slate-400">Failures</span>
            <span class="font-mono font-semibold text-navy">0.01%</span>
          </div>
        </div>

        <div class="pt-2 border-t border-divider">
          <div class="flex justify-between text-xs mb-2">
            <span class="font-mono text-slate-400">30 Days</span>
            <span class="font-mono font-semibold text-primary-container">100%</span>
          </div>
          <div class="flex items-end gap-[2px] h-10">
            <% 24.times do %>
              <div class="flex-1 bg-primary-container/70 rounded-sm" style="height: <%= rand(70..100) %>%"></div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ═══════════════════════════════════════════════
     Row 3: Recent Alerts Table
     ═══════════════════════════════════════════════ %>
  <div class="card space-y-0">
    <div class="flex items-center justify-between pb-4 border-b border-divider">
      <h2 class="text-lg font-semibold text-navy font-[Hanken_Grotesk]">Recent Alerts</h2>
      <span class="text-xs text-primary-container hover:underline cursor-pointer font-medium">View All</span>
    </div>

    <%# ── Column Headers ── %>
    <div class="grid grid-cols-[100px_120px_1fr_100px] gap-4 px-1 py-3 text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono border-b border-divider">
      <span>Severity</span>
      <span>Service</span>
      <span>Message</span>
      <span class="text-right">Time</span>
    </div>

    <%# ── Row 1: Critical ── %>
    <div class="grid grid-cols-[100px_120px_1fr_100px] gap-4 px-1 py-3 items-center list-row">
      <span class="chip chip-error text-[10px]">● Critical</span>
      <span class="text-sm font-semibold text-navy">Primary DB</span>
      <span class="text-xs text-slate-400 truncate">Connection pool exhaustion warning threshold reached (98%)</span>
      <span class="text-xs text-slate-400 font-mono text-right">10 mins ago</span>
    </div>

    <%# ── Row 2: Info ── %>
    <div class="grid grid-cols-[100px_120px_1fr_100px] gap-4 px-1 py-3 items-center list-row">
      <span class="chip chip-success text-[10px]">● Info</span>
      <span class="text-sm font-semibold text-navy">API Gateway</span>
      <span class="text-xs text-slate-400 truncate">Automated scaling event triggered. Added 4 nodes in us-east-1.</span>
      <span class="text-xs text-slate-400 font-mono text-right">2 hours ago</span>
    </div>

    <%# ── Row 3: Info ── %>
    <div class="grid grid-cols-[100px_120px_1fr_100px] gap-4 px-1 py-3 items-center list-row">
      <span class="chip chip-success text-[10px]">● Info</span>
      <span class="text-sm font-semibold text-navy">Storage Cluster</span>
      <span class="text-xs text-slate-400 truncate">Routine backup completed successfully across all regions.</span>
      <span class="text-xs text-slate-400 font-mono text-right">5 hours ago</span>
    </div>
  </div>
</div>
