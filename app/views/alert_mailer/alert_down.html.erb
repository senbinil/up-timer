<h1 style="font-family: 'Hanken Grotesk', sans-serif; font-size: 20px; color: #191c1e;">
  ⚠ <%= @alert.severity.upcase %> — <%= @monitor&.name || "System" %> is down
</h1>

<div style="background: #f7f9fb; border: 1px solid #e2e8f0; border-radius: 8px; padding: 16px; margin: 16px 0;">
  <p style="margin: 0 0 8px; font-size: 13px; color: #64748b;">
    <strong style="color: #191c1e;">Message:</strong> <%= @alert.message %>
  </p>
  <p style="margin: 0 0 8px; font-size: 13px; color: #64748b;">
    <strong style="color: #191c1e;">Severity:</strong> <%= @alert.severity.capitalize %>
  </p>
  <p style="margin: 0; font-size: 13px; color: #64748b;">
    <strong style="color: #191c1e;">Time:</strong> <%= @alert.created_at.strftime("%b %d, %Y at %H:%M:%S") %>
  </p>
</div>

<p style="font-size: 13px; color: #64748b;">
  Log in to UpTimer for full incident details.
</p>
