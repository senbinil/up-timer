<header class="flex items-center justify-between px-4 py-3 md:px-16 md:py-4 border-b border-border bg-surface-container-lowest">
  <div class="flex items-center gap-2.5">
    <%= link_to root_path, class: "flex items-center gap-2.5" do %>
      <%= image_tag "logo.svg", alt: "UpTimer", class: "w-7 h-7 rounded" %>
      <span class="text-lg font-semibold tracking-tight font-[Hanken_Grotesk] text-navy">UpTimer</span>
    <% end %>
  </div>

  <nav class="flex items-center gap-4">
    <!-- Help -->
    <button data-action="click->sidebar#openHelp" class="p-2 text-slate-400 hover:text-navy rounded-default hover:bg-surface-container-low transition-colors" title="Help">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </button>
  </nav>
</header>
