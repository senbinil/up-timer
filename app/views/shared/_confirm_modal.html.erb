<dialog id="confirm-modal" data-controller="confirm-modal" data-action="click->confirm-modal#clickOutside" class="m-auto rounded-lg p-0 border border-border bg-surface-container-lowest shadow-lg backdrop:bg-inverse-surface/30 max-w-sm w-full">
  <div class="p-4 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">Confirm</h2>
      <button data-action="confirm-modal#close" class="text-slate-400 hover:text-navy transition-colors">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>

    <p id="confirm-message" class="text-xs text-on-surface-variant"></p>

    <%= form_with url: "#", method: :post, id: "confirm-form", data: { turbo: true } do |f| %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <div class="flex gap-3 justify-end">
        <button type="button" data-action="confirm-modal#close" class="btn btn-secondary text-xs">Cancel</button>
        <button type="button" data-action="confirm-modal#proceed" class="btn btn-primary text-xs">Confirm</button>
      </div>
    <% end %>
  </div>
</dialog>
