<aside data-sidebar-target="sidebar" class="w-60 flex-col bg-surface-container-lowest border-r border-border h-screen sticky top-0 shrink-0 hidden lg:flex z-30">
  <%# ── Brand Header ── %>
  <div class="px-5 py-5 border-b border-border">
    <%= link_to root_path, class: "flex items-center gap-3" do %>
      <%= image_tag "logo.svg", alt: "UpTimer", class: "w-8 h-8 rounded" %>
      <div>
        <h2 class="text-sm font-semibold text-navy leading-tight">UpTimer</h2>
        <p class="text-[10px] uppercase tracking-[0.05em] text-slate-400 font-mono">Operational Hub</p>
      </div>
    <% end %>
  </div>

  <%# ── Navigation Links ── %>
  <nav class="flex-1 px-3 py-3 space-y-0.5">
    <% nav_items = [
      { icon: "grid", label: "Dashboard", path: dashboard_path },
      { icon: "server", label: "Nodes", path: nodes_path },
      { icon: "bell", label: "Alerts", path: alerts_path },
    ] %>
    <% nav_items << { icon: "radio", label: "Integrations", path: alert_integrations_path } if current_account&.admin? %>
    <% nav_items << { icon: "users", label: "Users", path: users_path } if current_account&.admin? %>
    <% nav_items.each do |item| %>
      <%= link_to item[:path], data: { action: "click->sidebar#close" }, class: "flex items-center gap-3 px-3 py-2 rounded-default text-sm transition-colors #{request.path == item[:path] ? 'bg-primary-container/10 text-primary-container font-medium' : 'text-navy hover:bg-surface-container-low'}" do %>
        <%= lucide_icon item[:icon], size: 16, class: "flex-shrink-0" %>
        <span><%= item[:label] %></span>
      <% end %>
    <% end %>

    <%= link_to root_path, class: "flex items-center gap-3 px-3 py-2 rounded-default text-sm transition-colors #{request.path == root_path ? 'bg-primary-container/10 text-primary-container font-medium' : 'text-slate-400 hover:text-navy hover:bg-surface-container-low'}" do %>
      <%= lucide_icon "globe", size: 16, class: "flex-shrink-0" %>
      <span>Public Status</span>
    <% end %>
  </nav>

  <%# ── Sidebar Footer ── %>
  <div class="px-4 pb-3 mt-auto">
    <hr class="border-divider mb-3" />
    <div class="space-y-0.5 mb-3">
    </div>

    <button data-action="theme#toggle" class="flex items-center gap-3 px-3 py-2 rounded-default text-sm text-slate-400 hover:text-navy hover:bg-surface-container-low transition-colors w-full">
      <%= lucide_icon "moon", size: 16, class: "flex-shrink-0" %>
      <span>Theme</span>
    </button>
    </div>
  </div>
</aside>
