<header class="flex items-center justify-between px-4 md:px-6 py-3 border-b border-[#e2e8f0] bg-white shrink-0">
  <div class="flex items-center gap-3">
    <button data-action="sidebar#toggle" class="lg:hidden p-1 -ml-1 text-slate-400 hover:text-navy rounded">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
    </button>
    <h1 class="text-sm font-semibold text-primary-container font-[Hanken_Grotesk]">Dashboard</h1>
  </div>

  <div class="flex items-center gap-2 md:gap-3">
    <% unless controller_name == "nodes" %>
      <%= link_to new_node_path, class: "btn btn-primary text-xs py-1.5 px-3" do %>
        Create Node &plus;
      <% end %>
    <% end %>

    <button class="flex items-center gap-1 text-xs md:text-xs text-slate-400 hover:text-navy transition-colors cursor-pointer">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" /></svg>
      <span class="hidden sm:inline">Help</span>
    </button>

    <div class="flex items-center gap-2 pl-2 md:pl-3 border-l border-divider relative" data-controller="dropdown" data-action="click@window->dropdown#close">
      <button data-action="dropdown#toggle" class="flex items-center gap-2 hover:bg-surface-container-low rounded-default px-1 py-0.5 transition-colors cursor-pointer">
        <div class="w-7 h-7 rounded-full bg-primary-container flex items-center justify-center text-white text-[10px] font-semibold flex-shrink-0">
          AU
        </div>
        <span class="text-xs font-semibold text-navy hidden sm:inline">Admin</span>
        <svg class="w-3 h-3 text-slate-400 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </button>

      <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-1 w-40 bg-white border border-[#e2e8f0] rounded-lg shadow-sm z-40">
        <%= link_to "#", data: { action: "dropdown#toggle" }, class: "flex items-center gap-2 px-3 py-2 text-xs text-navy hover:bg-surface-container-low rounded-t-lg transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          View Profile
        <% end %>
        <%= link_to "/logout", data: { turbo: false, action: "dropdown#toggle" }, class: "flex items-center gap-2 px-3 py-2 text-xs text-error hover:bg-error-container/30 rounded-b-lg transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" /></svg>
          Logout
        <% end %>
      </div>
    </div>
  </div>
</header>
