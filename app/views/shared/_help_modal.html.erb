<dialog id="help-modal" data-controller="help-modal" data-action="click->help-modal#clickOutside" class="m-auto rounded-lg p-0 border border-border bg-surface-container-lowest shadow-lg backdrop:bg-inverse-surface/30 max-w-sm w-full">
  <div class="p-4 space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">Help</h2>
      <button data-action="help-modal#close" class="text-slate-400 hover:text-navy transition-colors">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>

    <div class="space-y-2.5 text-xs text-navy leading-relaxed">
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono mb-1">Page Elements</p>
        <div class="space-y-2">
          <div>
            <p class="font-medium mb-0.5">System Status</p>
            <p class="text-on-surface-variant">Shows overall fleet health — <span class="font-mono text-success font-semibold">Operational</span> (all up),
            <span class="font-mono text-warning font-semibold">Degraded</span> (some down),
            <span class="font-mono text-error font-semibold">Down</span> (all down). The grid shows healthy, total, degraded, and alert counts.</p>
          </div>

          <div>
            <p class="font-medium mb-0.5">Service Cards</p>
            <p class="text-on-surface-variant">Each card shows a service name, URL, and a colored dot:
            <span class="font-mono text-success">green</span> = up,
            <span class="font-mono text-error">red</span> = down,
            <span class="font-mono text-warning">yellow</span> = paused/affected.
            Expand to see 24h uptime, response time, last check time, and incidents.</p>
          </div>

          <div>
            <p class="font-medium mb-0.5">Heat Strip</p>
            <p class="text-on-surface-variant">Colored bars for the last 24 checks — <span class="font-mono text-success">green</span> = up, <span class="font-mono text-error">red</span> = down. Hover any bar for the check time and status.</p>
          </div>

          <div>
            <p class="font-medium mb-0.5">Alerts</p>
            <p class="text-on-surface-variant">Recent unresolved alerts with severity, message, and affected service. Click to expand for full details.</p>
          </div>
        </div>
      </div>

      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono mb-1">Live Updates</p>
        <p class="text-on-surface-variant">Status, stats, and heat strips refresh automatically every few seconds. No page refresh needed.</p>
      </div>

      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono mb-1">UpTimer</p>
        <p class="text-on-surface-variant">Open-source uptime monitoring. Runs health checks, tracks response times, creates incidents on failure, and sends alerts. <a href="/login" class="text-primary-container hover:underline">Sign in</a> for the full dashboard.</p>
      </div>
    </div>
  </div>
</dialog>
