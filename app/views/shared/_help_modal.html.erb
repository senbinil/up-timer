<dialog id="help-modal" data-controller="help-modal" data-action="click->help-modal#clickOutside" class="m-auto rounded-lg p-0 border border-[#e2e8f0] bg-white shadow-lg backdrop:bg-navy/30 max-w-sm w-full">
  <div class="p-4 space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">Help</h2>
      <button data-action="help-modal#close" class="text-slate-400 hover:text-navy transition-colors">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
    </div>

    <div class="space-y-2.5 text-xs text-navy leading-relaxed">
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono mb-1">Intro</p>
        <p class="text-slate-600">UpTimer is a lightweight uptime monitoring dashboard that helps you track the health, response times, and availability of your services in real time.</p>
      </div>

      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono mb-1">Usage</p>
        <div class="space-y-2">
          <div>
            <p class="font-medium mb-0.5">Getting Started</p>
            <ol class="list-decimal pl-4 space-y-0.5 text-slate-600">
              <li><strong>Add a Node</strong> — Go to Nodes → Create Node, enter a name, URL, check interval, and timeout.</li>
              <li><strong>Monitor</strong> — The scheduler picks up new nodes within 30 seconds and starts running health checks automatically.</li>
              <li><strong>Dashboard</strong> — View all your services at a glance. Each card shows status, response time, and incident count.</li>
            </ol>
          </div>

          <div>
            <p class="font-medium mb-0.5">Statuses</p>
            <div class="flex gap-4 text-slate-600">
              <span><span class="font-mono text-success font-semibold">Up</span> — 2xx / 3xx</span>
              <span><span class="font-mono text-error font-semibold">Down</span> — 4xx / 5xx / error</span>
            </div>
          </div>

          <div>
            <p class="font-medium mb-0.5">Incidents</p>
            <p class="text-slate-600">Created automatically on failure, resolved on recovery.</p>
          </div>

          <div>
            <p class="font-medium mb-0.5">Data Retention</p>
            <p class="text-slate-600">Checks purged after <strong>30 days</strong>. Resolved incidents after <strong>90 days</strong>.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</dialog>
