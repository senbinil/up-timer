<%# Fleet status section %>
<%= turbo_stream.replace "public_fleet_status" do %>
  <div id="public_fleet_status" class="card space-y-5">
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full <%= @stats[:status] == "operational" ? "bg-success" : (@stats[:status] == "degraded" ? "bg-warning" : "bg-error") %>"></span>
      <span class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">System Status</span>
    </div>

    <div>
      <h1 class="text-2xl md:text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk] capitalize"><%= @stats[:status] %></h1>
      <p class="text-sm text-slate-400 mt-1"><%= @stats[:up_count] %> of <%= @stats[:total] %> services healthy<% if @stats[:down_count] > 0 %>, <%= @stats[:down_count] %> degraded<% end %>.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-4 border-t border-divider">
      <div>
        <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Healthy</p>
        <p class="text-lg font-semibold text-success font-[Hanken_Grotesk] mt-1"><%= @stats[:up_count] %></p>
      </div>
      <div>
        <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Total</p>
        <p class="text-lg font-semibold text-navy font-[Hanken_Grotesk] mt-1"><%= @stats[:total] %></p>
      </div>
      <div>
        <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Degraded</p>
        <p class="text-lg font-semibold <%= @stats[:down_count] > 0 ? "text-error" : "text-navy" %> font-[Hanken_Grotesk] mt-1"><%= @stats[:down_count] %></p>
      </div>
      <div>
        <p class="text-xs text-slate-400 font-mono uppercase tracking-[0.05em]">Active Alerts</p>
        <p class="text-lg font-semibold <%= @alert_counts.values.sum > 0 ? "text-warning" : "text-navy" %> font-[Hanken_Grotesk] mt-1"><%= @alert_counts.values.sum %></p>
        <% if @alert_counts.values.sum > 0 %>
          <p class="text-[10px] font-mono mt-0.5">
            <% if @alert_counts["critical"].to_i > 0 %><span class="text-error"><%= @alert_counts["critical"] %> crit</span><% end %>
            <% if @alert_counts["warning"].to_i > 0 %><span class="text-warning ml-1"><%= @alert_counts["warning"] %> warn</span><% end %>
          </p>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-2 pt-3 border-t border-divider text-[10px] text-slate-400 font-mono">
      <%= lucide_icon "clock", size: 12, class: "flex-shrink-0" %>
      <% if @last_resolved %>
        Last incident resolved <%= time_ago_in_words(@last_resolved) %> ago ·
      <% end %>
      Updated <%= time_ago_in_words(MonitorCheck.maximum(:checked_at) || Time.current) %> ago
    </div>
  </div>
<% end %>

<%# Updated public node detail elements (summary + expanded stats + chart) %>
<% @updated_nodes.each do |node| %>
  <% stats = node.public_uptime %>
  <%= turbo_stream.action :morph, dom_id(node) do %>
    <details id="<%= dom_id(node) %>" class="card p-0 group open:ring-1 open:ring-primary-container/30 transition-all">
      <summary class="flex items-center gap-4 py-3 px-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:bg-surface-container-low transition-colors rounded-lg">
        <span class="w-2.5 h-2.5 rounded-full <%= node.paused? ? 'bg-[var(--color-warning)]' : (node.status == "up" && !node.dependency_affected? ? "bg-success" : node.dependency_affected? ? "bg-warning" : "bg-error") %> flex-shrink-0"></span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-navy truncate"><%= node.name %></p>
          <p class="text-[11px] text-slate-400 font-mono truncate"><%= node.url %></p>
          <% if (last = node.monitor_checks.order(checked_at: :desc).first) %>
            <p class="text-[10px] text-slate-400 font-mono mt-0.5">Checked <%= time_ago_in_words(last.checked_at) %> ago</p>
          <% end %>
        </div>
        <div class="flex items-center gap-3 flex-shrink-0">
          <% if stats[:uptime] %>
            <span class="text-[10px] font-mono <%= stats[:uptime] >= 99 ? "text-success" : stats[:uptime] >= 95 ? "text-warning" : "text-error" %>"><%= stats[:uptime] %>% rates</span>
          <% end %>
          <span class="text-xs font-mono font-semibold <%= node.paused? ? 'text-[var(--color-warning)]' : (node.status == "up" && !node.dependency_affected? ? "text-success" : node.dependency_affected? ? "text-warning" : "text-error") %> flex-shrink-0"><%= node.paused? ? "PAUSED" : (node.dependency_affected? ? "Affected" : node.status&.upcase) %></span>
          <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </div>
      </summary>

      <div class="px-4 pb-4 pt-2 border-t border-divider space-y-4">
        <% if stats[:uptime] %>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div>
              <p class="text-[10px] text-slate-400 font-mono uppercase tracking-[0.05em]">24h Uptime</p>
              <p class="text-lg font-semibold <%= stats[:uptime] >= 99 ? "text-success" : stats[:uptime] >= 95 ? "text-warning" : "text-error" %> font-[Hanken_Grotesk] mt-0.5"><%= stats[:uptime] %>%</p>
            </div>
            <div>
              <p class="text-[10px] text-slate-400 font-mono uppercase tracking-[0.05em]">Response</p>
              <p class="text-lg font-semibold text-navy font-[Hanken_Grotesk] mt-0.5"><%= stats[:response_time] ? "#{stats[:response_time]}ms" : "—" %></p>
            </div>
            <div>
              <p class="text-[10px] text-slate-400 font-mono uppercase tracking-[0.05em]">Last Check</p>
              <p class="text-lg font-semibold text-navy font-[Hanken_Grotesk] mt-0.5"><%= node.last_check_at ? node.last_check_at.strftime("%I:%M %p") : "—" %></p>
            </div>
            <div>
              <p class="text-[10px] text-slate-400 font-mono uppercase tracking-[0.05em]">Incidents</p>
              <p class="text-lg font-semibold <%= node.incidents.where(resolved_at: nil).any? ? "text-error" : "text-navy" %> font-[Hanken_Grotesk] mt-0.5"><%= node.incidents.where(resolved_at: nil).count %></p>
            </div>
          </div>

          <% if stats[:recent_checks].size > 1 %>
            <div>
              <p class="text-[10px] text-slate-400 font-mono uppercase tracking-[0.05em] mb-2">Recent Response</p>
              <%= area_chart stats[:recent_checks], height: "80px", colors: ["#2563eb"], legend: false, library: { scales: { x: { display: false }, y: { display: false } } } %>
            </div>
          <% end %>
        <% else %>
          <p class="text-xs text-slate-400 py-4 text-center">No check data yet for this service.</p>
        <% end %>
      </div>
    </details>
  <% end %>
<% end %>

<%# Recent alerts (prepend new ones) %>
<% @new_alerts.each do |alert| %>
  <%= turbo_stream.prepend "public_recent_alerts" do %>
    <details class="group">
      <summary class="flex items-center gap-3 text-xs py-2 px-1 border-b border-divider last:border-0 cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:bg-surface-container-low transition-colors rounded-sm">
        <span class="<%= alert.severity == 'critical' ? 'text-error' : (alert.severity == 'warning' ? 'text-warning' : 'text-slate-400') %> font-mono font-semibold w-16 flex-shrink-0"><%= alert.severity.upcase %></span>
        <% if alert.resolved? %>
          <span class="chip chip-success text-[10px] flex-shrink-0">resolved</span>
        <% end %>
        <span class="text-on-surface-variant truncate flex-1"><%= alert.message %></span>
        <span class="text-slate-400 font-mono flex-shrink-0"><%= time_ago_in_words(alert.created_at) %> ago</span>
        <svg class="w-3 h-3 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
      </summary>

      <div class="px-1 py-3 border-b border-divider bg-surface-container-low/50 space-y-2 text-xs">
        <div class="flex items-start gap-4">
          <span class="text-slate-400 font-mono flex-shrink-0">Message:</span>
          <span class="text-navy"><%= alert.message %></span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-slate-400 font-mono">Service:</span>
          <span class="text-navy font-medium"><%= alert.monitor&.name || "System" %></span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-slate-400 font-mono">Severity:</span>
          <span class="<%= alert.severity == 'critical' ? 'text-error' : (alert.severity == 'warning' ? 'text-warning' : 'text-slate-400') %> font-mono font-semibold"><%= alert.severity.upcase %></span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-slate-400 font-mono">Created:</span>
          <span class="text-navy font-mono"><%= alert.created_at.strftime("%b %d, %I:%M %p") %></span>
        </div>
        <% if alert.resolved? && alert.resolved_at %>
          <div class="flex items-center gap-4">
            <span class="text-slate-400 font-mono">Resolved:</span>
            <span class="text-navy font-mono"><%= alert.resolved_at.strftime("%b %d, %I:%M %p") %> (<%= distance_of_time_in_words(alert.created_at, alert.resolved_at) %>)</span>
          </div>
        <% end %>
        <% if alert.resolved_by %>
          <div class="flex items-center gap-4">
            <span class="text-slate-400 font-mono">Resolved by:</span>
            <span class="text-navy"><%= alert.resolved_by.name || alert.resolved_by.email %></span>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>
<% end %>
