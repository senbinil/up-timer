<!DOCTYPE html>
<html>
  <head>
    <title><%= @page_title || content_for(:title) || "Up Timer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Up Timer">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-body min-h-screen flex">
    <%= render "shared/sidebar" %>

    <div class="flex-1 flex flex-col min-w-0">
      <%= render "shared/dashboard_header" %>

      <% if notice %>
        <div class="flash-notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash-alert"><%= alert %></div>
      <% end %>

      <main class="flex-1 bg-surface overflow-auto p-6 md:p-8">
        <%= yield %>
      </main>

      <%= render "shared/footer" %>
    </div>
  </body>
</html>
