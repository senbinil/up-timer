<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title><%= @page_title || content_for(:title) || "Up Timer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="Up Timer">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#f7f9fb">
    <script>
      (function() {
        if (localStorage.getItem("theme") === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/logo.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://unpkg.com/tippy.js@6/dist/tippy.css">
    <script src="https://unpkg.com/@popperjs/core@2"></script>
    <script src="https://unpkg.com/tippy.js@6"></script>
    <%= javascript_importmap_tags %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>lucide.createIcons();</script>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/service-worker.js')
      }
    </script>
  </head>

  <body class="font-body min-h-screen flex flex-col" data-controller="sidebar">
    <%= render "shared/header" %>

    <% if notice || alert %>
      <div id="flash" class="max-w-lg mx-auto mt-4 px-4">
        <%= render "shared/flash" %>
      </div>
    <% end %>

    <main class="flex-1 flex items-center justify-center py-8 md:py-16">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
    <%= render "shared/confirm_modal" %>
  </body>
</html>
