<!DOCTYPE html>
<html>
  <head>
    <title>Status — UpTimer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f7f9fb">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="font-body min-h-screen bg-surface">
    <header class="flex items-center justify-between px-6 py-4 border-b border-[#e2e8f0] bg-white">
      <div class="flex items-center gap-3">
        <div class="w-7 h-7 bg-primary-container rounded-default flex items-center justify-center">
          <span class="text-white font-semibold text-xs">O</span>
        </div>
        <span class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">UpTimer Status</span>
      </div>
      <span class="text-[10px] text-slate-400 font-mono">Public</span>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <%= yield %>
    </main>

    <footer class="text-center py-6 text-[10px] text-slate-400 font-mono border-t border-[#e2e8f0]">
      Powered by UpTimer
    </footer>
  </body>
</html>
