<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title>Status — UpTimer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f7f9fb">
    <script>
      (function() {
        if (localStorage.getItem("theme") === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/logo.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="font-body min-h-screen bg-surface">
    <header class="flex items-center justify-between px-6 py-4 border-b border-border bg-surface-container-lowest">
      <div class="flex items-center gap-3">
        <%= image_tag "logo.svg", alt: "UpTimer", class: "w-7 h-7 rounded" %>
        <span class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">UpTimer Status</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-[10px] text-slate-400 font-mono">Public</span>
        <button data-action="theme#toggle" class="p-1.5 text-slate-400 hover:text-navy rounded-default hover:bg-surface-container-low transition-colors" title="Toggle theme">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-8 space-y-6">
      <%= yield %>
    </main>

    <footer class="text-center py-6 text-[10px] text-slate-400 font-mono border-t border-border">
      Powered by UpTimer
    </footer>
  </body>
</html>
