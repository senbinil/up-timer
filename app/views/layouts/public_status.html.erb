<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title>Status — UpTimer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f7f9fb">
    <script>
      (function() {
        if (localStorage.getItem("theme") === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/logo.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://unpkg.com/tippy.js@6/dist/tippy.css">
    <%= javascript_importmap_tags %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>document.addEventListener("turbo:load", () => lucide.createIcons());document.addEventListener("turbo:render", () => lucide.createIcons());lucide.createIcons();</script>

    <script src="https://unpkg.com/@popperjs/core@2"></script>
    <script src="https://unpkg.com/tippy.js@6"></script>
  </head>
  <body class="font-body min-h-screen bg-surface">
    <div data-controller="mobile-nav" data-action="click->mobile-nav#close keydown->mobile-nav#closeKey@window">
    <header class="flex items-center justify-between px-6 py-4 border-b border-border bg-surface-container-lowest">
      <div class="flex items-center gap-3">
        <%= link_to root_path, class: "flex items-center gap-3" do %>
          <%= image_tag "logo.svg", alt: "UpTimer", class: "w-7 h-7 rounded" %>
          <span class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">UpTimer Status</span>
        <% end %>
      </div>

      <%# Desktop nav — hidden on mobile, visible on md+ %>
      <nav class="hidden md:flex items-center gap-5">
        <% if current_account %>
          <%= link_to dashboard_path, class: "flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" do %>
            <%= lucide_icon "layout-dashboard", size: 14 %>
            Dashboard
          <% end %>
        <% else %>
          <%= link_to "/login", class: "flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" do %>
            <%= lucide_icon "log-in", size: 14 %>
            Log In
          <% end %>
          <%= link_to "/create-account", class: "flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" do %>
            <%= lucide_icon "user-plus", size: 14 %>
            Create Account
          <% end %>
        <% end %>
        <span class="h-4 w-px bg-border"></span>
        <span class="text-[11px] text-slate-400 font-mono uppercase tracking-wider">Public</span>
        <button onclick="document.getElementById('help-modal')?.showModal()" class="p-1.5 text-slate-400 hover:text-navy rounded-default hover:bg-surface-container-low transition-colors" title="Help">
          <%= lucide_icon "help-circle", size: 16 %>
        </button>
        <button data-action="theme#toggle" class="p-1.5 text-slate-400 hover:text-navy rounded-default hover:bg-surface-container-low transition-colors" title="Toggle theme">
          <%= lucide_icon "moon", size: 16 %>
        </button>
      </nav>

      <%# Mobile hamburger button — visible on mobile, hidden on md+ %>
      <button data-action="mobile-nav#toggle" class="md:hidden flex items-center gap-1.5 p-1.5 text-slate-400 hover:text-navy rounded-default hover:bg-surface-container-low transition-colors" title="Toggle navigation menu">
        <span data-mobile-nav-target="menuIconWrap" class="flex items-center"><%= lucide_icon "menu", size: 20 %></span>
        <span data-mobile-nav-target="closeIconWrap" class="hidden flex items-center"><%= lucide_icon "x", size: 20 %></span>
      </button>
    </header>

    <%# Mobile dropdown menu — hidden by default, animated slide-down %>
    <div data-mobile-nav-target="menu" class="mobile-menu md:hidden border-b border-border bg-surface-container-lowest px-6 space-y-3" style="padding-top: 0; padding-bottom: 0;">
      <div class="pt-4 pb-4 space-y-3">
        <% if current_account %>
          <%= link_to dashboard_path, class: "flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" do %>
            <%= lucide_icon "layout-dashboard", size: 14 %>
            Dashboard
          <% end %>
        <% else %>
          <%= link_to "/login", class: "flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" do %>
            <%= lucide_icon "log-in", size: 14 %>
            Log In
          <% end %>
          <%= link_to "/create-account", class: "flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" do %>
            <%= lucide_icon "user-plus", size: 14 %>
            Create Account
          <% end %>
        <% end %>
        <hr class="border-border" />
        <div class="space-y-3">
          <div class="flex items-center gap-1.5 text-[11px] text-slate-400 font-mono uppercase tracking-wider">
            <%= lucide_icon "globe", size: 14 %>
            Public
          </div>
          <div class="space-y-3">
            <button onclick="document.getElementById('help-modal')?.showModal()" class="flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" title="Help">
              <%= lucide_icon "help-circle", size: 14 %>
              Help
            </button>
            <button data-action="theme#toggle" class="flex items-center gap-1.5 text-[13px] text-slate-500 hover:text-navy font-medium transition-colors" title="Toggle theme">
              <%= lucide_icon "moon", size: 14 %>
              Theme
            </button>
          </div>
        </div>
      </div>
    </div>
    </div>

    <div id="flash" class="max-w-3xl mx-auto px-4 pt-4">
      <%= render "shared/flash" %>
    </div>

    <main class="max-w-3xl mx-auto px-4 py-8 space-y-6" data-controller="dashboard-receiver">
      <%= yield %>
    </main>

    <footer class="text-center py-6 text-[10px] text-slate-400 font-mono border-t border-border">
      Powered by UpTimer
    </footer>
    <%= render "shared/help_modal" %>
  </body>
</html>
