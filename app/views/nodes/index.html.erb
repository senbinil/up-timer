<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-navy font-[Hanken_Grotesk]">Nodes</h1>
    <%= link_to "Create Node +", new_node_path, class: "btn btn-primary text-xs py-1.5 px-3" %>
  </div>

  <% if @nodes.any? %>
    <div class="card space-y-0">
      <div class="hidden md:grid grid-cols-[1fr_1fr_100px_100px_80px] gap-4 px-1 py-3 text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono border-b border-divider">
        <span>Name</span>
        <span>URL</span>
        <span>Interval</span>
        <span>Timeout</span>
        <span>Status</span>
      </div>
      <% @nodes.each do |node| %>
        <div class="md:grid md:grid-cols-[1fr_1fr_100px_100px_80px] gap-4 px-1 py-3 items-center list-row">
          <span class="text-sm font-semibold text-navy"><%= node.name %></span>
          <span class="text-xs text-slate-400 font-mono truncate hidden md:block"><%= node.url %></span>
          <span class="text-xs text-slate-400 font-mono"><%= node.check_interval %>s</span>
          <span class="text-xs text-slate-400 font-mono"><%= node.timeout %>s</span>
          <span class="<%= node.status == "up" ? "chip chip-success" : "chip chip-error" %> text-[10px]"><%= node.status %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12 text-slate-400">
      <p class="text-body-lg">No nodes yet.</p>
      <p class="text-xs mt-1">Click "Create Node" to start monitoring.</p>
    </div>
  <% end %>
</div>
