<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-navy font-[Hanken_Grotesk]">Nodes</h1>
    <%= link_to "Create Node +", new_node_path, class: "btn btn-primary text-xs py-1.5 px-3" %>
  </div>

  <% if @nodes.any? %>
    <div class="card space-y-0">
      <div class="hidden md:grid grid-cols-[40px_1fr_1fr_1fr_80px_80px_80px_80px_100px] gap-2 px-1 py-3 text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono border-b border-divider">
        <span>#</span>
        <span>Name</span>
        <span>URL</span>
        <span>Tags</span>
        <span>Interval</span>
        <span>Timeout</span>
        <span>Status</span>
        <span></span>
        <span>Actions</span>
      </div>
      <% @nodes.each.with_index(1) do |node, index| %>
        <div class="hidden md:grid md:grid-cols-[40px_1fr_1fr_1fr_80px_80px_80px_80px_100px] gap-2 px-1 py-3 items-center list-row hover:bg-surface-container-low">
          <span class="text-xs font-mono text-slate-400"><%= index %></span>
          <%= link_to node.name, node_path(node), class: "text-sm font-semibold text-navy hover:underline" %>
          <%= link_to node.url, node_path(node), class: "text-xs text-slate-400 font-mono truncate hover:underline" %>
          <span class="flex flex-wrap items-center gap-1">
            <turbo-frame id="<%= dom_id(node, :tags) %>" style="display: contents">
              <% node.tags.each do |tag| %>
                <span class="chip chip-success text-[10px]"><%= tag %></span>
              <% end %>
            </turbo-frame>
            <button data-controller="tag-picker"
                    data-tag-picker-node-id-value="<%= node.id %>"
                    data-tag-picker-tags-value="<%= node.tags.to_json %>"
                    data-tag-picker-all-tags-value="<%= UptimeMonitor.all_tags.to_json %>"
                    data-action="click->tag-picker#toggle"
                    class="inline-flex items-center justify-center w-5 h-5 rounded-full border border-dashed border-slate-300 text-slate-400 hover:border-primary-container hover:text-primary-container hover:bg-primary-container/5 transition-colors text-xs font-mono cursor-pointer ml-0.5" title="Add tag">+</button>
          </span>
          <span class="text-xs text-slate-400 font-mono"><%= node.check_interval %>s</span>
          <span class="text-xs text-slate-400 font-mono"><%= node.timeout %>s</span>
          <span id="<%= dom_id(node, :status) %>" class="text-[10px]">
            <% if node.paused? %>
              <% pause_log = node.last_pause_log %>
              <span class="chip chip-warning" title="<%= pause_log ? "Paused by #{pause_log.account&.name || pause_log.account&.email || 'unknown'} · #{time_ago_in_words(pause_log.created_at)} ago" : "Paused" %>">Paused</span>
            <% else %>
              <span class="<%= node.status == "up" ? "chip chip-success" : "chip chip-error" %>"><%= node.status %></span>
            <% end %>
          </span>
          <span class="flex items-center gap-1">
            <%= button_to "&#9650;".html_safe, move_up_node_path(node), method: :post, class: "text-[10px] text-slate-400 hover:text-navy p-0.5 cursor-pointer", title: "Move up" %>
            <%= button_to "&#9660;".html_safe, move_down_node_path(node), method: :post, class: "text-[10px] text-slate-400 hover:text-navy p-0.5 cursor-pointer", title: "Move down" %>
          </span>
          <span id="<%= dom_id(node, :pause) %>" class="flex items-center gap-1">
            <%= render partial: "nodes/pause_button", locals: { node: node } %>
          </span>
        </div>

        <%# Mobile layout %>
        <%= link_to node_path(node), class: "md:hidden flex items-center gap-3 px-1 py-3 list-row hover:bg-surface-container-low" do %>
          <span class="flex-1 min-w-0">
            <span class="text-sm font-semibold text-navy block"><%= node.name %></span>
            <span class="text-xs text-slate-400 font-mono truncate block"><%= node.url %></span>
          </span>
          <span class="text-[10px]">
            <% if node.paused? %>
              <span class="chip chip-warning">Paused</span>
            <% else %>
              <span class="<%= node.status == "up" ? "chip chip-success" : "chip chip-error" %>"><%= node.status %></span>
            <% end %>
          </span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12 text-slate-400">
      <p class="text-body-lg">No nodes yet.</p>
      <p class="text-xs mt-1">Click "Create Node" to start monitoring.</p>
    </div>
  <% end %>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center pt-4">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
