<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-navy font-[Hanken_Grotesk]">Nodes</h1>
    <%= link_to "Create Node +", new_node_path, class: "btn btn-primary text-xs py-1.5 px-3" %>
  </div>

  <% if @nodes.any? %>
    <div class="card space-y-0">
      <div class="hidden md:grid grid-cols-[40px_1fr_1fr_80px_80px_80px_80px] gap-2 px-1 py-3 text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono border-b border-divider">
        <span>#</span>
        <span>Name</span>
        <span>URL</span>
        <span>Interval</span>
        <span>Timeout</span>
        <span>Status</span>
        <span></span>
      </div>
      <% @nodes.each.with_index(1) do |node, index| %>
        <%= link_to node_path(node), class: "md:grid md:grid-cols-[40px_1fr_1fr_80px_80px_80px_80px] gap-2 px-1 py-3 items-center list-row block hover:bg-surface-container-low" do %>
          <span class="text-xs font-mono text-slate-400 hidden md:block"><%= index %></span>
          <span class="text-sm font-semibold text-navy"><%= node.name %></span>
          <span class="text-xs text-slate-400 font-mono truncate hidden md:block"><%= node.url %></span>
          <span class="text-xs text-slate-400 font-mono"><%= node.check_interval %>s</span>
          <span class="text-xs text-slate-400 font-mono"><%= node.timeout %>s</span>
          <span class="<%= node.status == "up" ? "chip chip-success" : "chip chip-error" %> text-[10px]"><%= node.status %></span>
          <span class="flex items-center gap-1" onclick="event.preventDefault()">
            <%= button_to "&#9650;".html_safe, move_up_node_path(node), method: :post, class: "text-[10px] text-slate-400 hover:text-navy p-0.5 cursor-pointer", title: "Move up" %>
            <%= button_to "&#9660;".html_safe, move_down_node_path(node), method: :post, class: "text-[10px] text-slate-400 hover:text-navy p-0.5 cursor-pointer", title: "Move down" %>
          </span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12 text-slate-400">
      <p class="text-body-lg">No nodes yet.</p>
      <p class="text-xs mt-1">Click "Create Node" to start monitoring.</p>
    </div>
  <% end %>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center pt-4">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
