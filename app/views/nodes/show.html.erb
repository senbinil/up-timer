<div class="space-y-6">
  <div class="flex items-center gap-3">
    <%= link_to nodes_path, class: "text-slate-400 hover:text-navy transition-colors" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
    <% end %>
    <div class="flex-1">
      <p class="text-xs font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Node Detail</p>
      <h1 class="text-2xl md:text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk]"><%= @node.name %></h1>
    </div>
    <%= link_to "Edit", edit_node_path(@node), class: "btn btn-primary text-xs" %>
  </div>

  <div id="<%= dom_id(@node, :paused_banner) %>">
    <% if @node.paused? %>
      <% pause_log = @node.last_pause_log %>
      <div class="bg-warning-container border border-warning text-on-warning-container rounded-default p-3 text-xs flex items-center gap-2">
        <span>⏸</span>
        <div>
          <p>This node is paused. Health checks are not running.</p>
          <% if pause_log %>
            <p class="text-[10px] mt-1 opacity-80">Paused by <%= pause_log.account&.name || pause_log.account&.email || "unknown" %> &middot; <%= time_ago_in_words(pause_log.created_at) %> ago</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Node Info Cards ── %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Status</p>
      <span id="<%= dom_id(@node, :status) %>" class="mt-2 inline-block">
        <% if @node.paused? %>
          <span class="chip chip-warning text-[10px]">Paused</span>
        <% else %>
          <span class="<%= @node.status == "up" ? "chip chip-success" : "chip chip-error" %> text-[10px]"><%= @node.status %></span>
        <% end %>
      </span>
    </div>
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">URL</p>
      <p class="text-sm font-mono text-navy mt-1 break-all"><span class="chip chip-default text-[10px] mr-2"><%= @node.request_type %></span><%= @node.url %></p>
    </div>
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Check Interval</p>
      <p class="text-lg font-semibold text-navy mt-1"><%= @node.check_interval %>s</p>
    </div>
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Timeout</p>
      <p class="text-lg font-semibold text-navy mt-1"><%= @node.timeout %>s</p>
    </div>
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Tags</p>
      <div class="flex flex-wrap gap-1 mt-1">
        <turbo-frame id="<%= dom_id(@node, :tags) %>" style="display: contents">
          <% if @node.tags.any? %>
            <% @node.tags.each do |tag| %>
              <span class="chip chip-success text-[10px]"><%= tag %></span>
            <% end %>
          <% else %>
            <span class="text-xs text-slate-400 font-mono">—</span>
          <% end %>
        </turbo-frame>
      </div>
    </div>
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Failure Threshold</p>
      <p class="text-lg font-semibold text-navy mt-1"><%= @node.down_threshold %></p>
    </div>
    <% if current_account&.admin? %>
    <div class="card">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Monitoring</p>
      <span id="<%= dom_id(@node, :pause) %>" class="mt-2 block">
        <%= render partial: "nodes/pause_button", locals: { node: @node } %>
      </span>
    </div>
    <% end %>
  </div>

  <%# ── SSL Info ── %>
  <% latest_check = @node.monitor_checks.where.not(ssl_valid: nil).order(checked_at: :desc).first %>
  <% if latest_check %>
    <div class="card space-y-3">
      <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">SSL Certificate</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div>
          <span class="<%= latest_check.ssl_valid ? "chip chip-success" : "chip chip-error" %> text-[10px]"><%= latest_check.ssl_valid ? "Valid" : "Invalid" %></span>
        </div>
        <div>
          <% days = latest_check.ssl_days_remaining %>
          <span class="chip text-[10px] <%= days && days <= 0 ? "chip-error" : (days && days <= 30 ? "chip-warning" : "chip-success") %>">
            <%= days ? (days <= 0 ? "Expired" : "#{days}d remaining") : "—" %>
          </span>
        </div>
        <div class="col-span-2">
          <p class="text-xs font-mono text-slate-500"><%= latest_check.ssl_subject %></p>
          <p class="text-[10px] font-mono text-slate-400"><%= latest_check.ssl_issuer %></p>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Response Time Chart ── %>
  <% unless @node.paused? %>
  <div class="card space-y-3">
    <h2 class="text-sm font-semibold text-navy font-[Hanken_Grotesk]">Response Time (ms)</h2>
    <% if @checks.any? %>
      <% chart_data = @checks.first(24).reverse.map { |c| [c.checked_at.strftime("%I:%M %p"), c.response_time] }.to_h %>
      <%= area_chart chart_data, height: "200px", colors: ["#2563eb"], library: { scales: { y: { beginAtZero: true } } } %>
    <% else %>
      <p class="text-xs text-slate-400 py-8 text-center">No check data yet.</p>
    <% end %>
  </div>
  <% end %>

  <%# ── Recent Checks Table ── %>
  <%= turbo_frame_tag "node_checks" do %>
  <div class="card space-y-0">
    <h2 class="text-sm font-semibold text-navy font-[Hanken_Grotesk] pb-4 border-b border-divider flex items-center justify-between">
      <span>Recent Checks</span>
      <div class="flex items-center gap-2">
        <span class="text-[10px] text-slate-400 font-mono">Show:</span>
        <% [10, 25, 50, 100].each do |n| %>
          <%= link_to n, node_path(@node, per_page: n), data: { turbo_frame: "node_checks" }, class: "text-[10px] font-mono px-1.5 py-0.5 rounded-default border #{(params[:per_page].to_i == n || (params[:per_page].blank? && n == 25)) ? 'border-primary-container bg-primary-container/10 text-primary-container' : 'border-border text-slate-400 hover:text-navy'} transition-colors" %>
        <% end %>
        <span class="text-[10px] text-slate-400 font-mono">per page</span>
      </div>
    </h2>
    <% if @checks.any? %>
      <div class="hidden md:grid grid-cols-[60px_50px_1fr_80px_160px] gap-4 px-1 py-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono border-b border-divider">
        <span>Status</span>
        <span>Code</span>
        <span>Response</span>
        <span>SSL</span>
        <span class="text-right">Checked At</span>
      </div>
      <% @checks.each do |check| %>
        <div class="md:grid md:grid-cols-[60px_50px_1fr_80px_160px] gap-4 px-1 py-2 items-center list-row">
          <span class="<%= check.status == "up" ? "chip chip-success" : "chip chip-error" %> text-[10px]"><%= check.status %></span>
          <span class="text-xs font-mono <%= check.status_code && check.status_code >= 400 ? "text-error" : "text-navy" %>"><%= check.status_code || "-" %></span>
          <span class="text-xs text-slate-400 font-mono"><%= check.response_time ? "#{check.response_time}ms" : "-" %></span>
          <span class="text-[10px] font-mono">
            <% if check.ssl_valid == true %>
              <span class="text-success">✓</span>
            <% elsif check.ssl_valid == false %>
              <span class="text-error">✗</span>
            <% else %>
              <span class="text-slate-300">—</span>
            <% end %>
          </span>
          <span class="text-xs text-slate-400 font-mono md:text-right"><%= check.checked_at.strftime("%b %d, %I:%M:%S %p") %></span>
        </div>
      <% end %>
    <% else %>
      <p class="text-xs text-slate-400 py-8 text-center">No checks recorded yet.</p>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center pt-4">
      <%== @pagy.series_nav %>
    </div>
    <% end %>
  <% end %>

  <div class="flex gap-3 pt-8">
    <%= button_to "Delete Node", node_path(@node), method: :delete, class: "btn btn-ghost text-xs text-error", form: { data: { turbo_confirm: "Delete this node and all its checks?" } } %>
  </div>
</div>
