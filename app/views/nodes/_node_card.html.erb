<%= content_tag :div, id: dom_id(node) do %>
  <%= link_to node_path(node), data: { turbo_prefetch: false }, class: "card space-y-4 block hover:border-primary-container/30 transition-colors" do %>
    <div class="flex items-start justify-between">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-9 h-9 rounded-default bg-primary-container/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-container" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        </div>
        <div class="min-w-0">
          <h3 class="text-sm font-semibold text-navy truncate"><%= node.name %></h3>
          <p class="text-[11px] text-slate-400 font-mono truncate"><%= node.url %></p>
        </div>
      </div>
      <span class="w-2 h-2 rounded-full <%= node.paused? ? "bg-[var(--color-warning)]" : (node.status == "up" ? "bg-primary-container" : "bg-error") %> flex-shrink-0 mt-1.5"></span>
    </div>

    <div class="space-y-2 pt-2 border-t border-divider">
      <div class="flex justify-between text-xs">
        <span class="font-mono text-slate-400">Response</span>
        <span class="font-mono font-semibold text-navy"><%= node.monitor_checks.last&.response_time ? "#{node.monitor_checks.last.response_time}ms" : "-" %></span>
      </div>
      <div class="flex justify-between text-xs">
        <span class="font-mono text-slate-400">Last Check</span>
        <span class="font-mono font-semibold text-navy"><%= node.last_check_at ? node.last_check_at.strftime("%I:%M %p") : "—" %></span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-1 pt-1" onclick="event.stopPropagation()">
      <turbo-frame id="<%= dom_id(node, :tags) %>" style="display: contents">
        <% node.tags.each do |tag| %>
          <span class="chip chip-success text-[10px]"><%= tag %></span>
        <% end %>
      </turbo-frame>
      <button data-controller="tag-picker"
              data-tag-picker-node-id-value="<%= node.id %>"
              data-tag-picker-tags-value="<%= node.tags.to_json %>"
              data-tag-picker-all-tags-value="<%= UptimeMonitor.all_tags.to_json %>"
              data-action="click->tag-picker#toggle"
              class="inline-flex items-center justify-center w-5 h-5 rounded-full border border-dashed border-slate-300 text-slate-400 hover:border-primary-container hover:text-primary-container hover:bg-primary-container/5 transition-colors text-xs font-mono cursor-pointer ml-0.5" title="Add tag">+</button>
    </div>

    <div class="pt-2 border-t border-divider">
      <div class="flex justify-between text-xs mb-2">
        <span class="font-mono text-slate-400">Status</span>
        <span class="font-mono font-semibold <%= node.paused? ? "text-[var(--color-warning)]" : (node.status == "up" ? "text-primary-container" : "text-error") %>"><%= node.paused? ? "PAUSED" : node.status&.upcase %></span>
      </div>
      <div class="flex gap-0.5 h-4">
        <% node.status_heatmap.each do |s| %>
          <span class="flex-1 rounded-sm <%= s[:status] == "up" ? "bg-success" : "bg-error" %>" data-controller="tooltip" data-tooltip-content-value="<%= s[:checked_at].strftime("%I:%M %p") %> — <%= s[:status].upcase %>"></span>
        <% end %>
      </div>
      <span class="text-[9px] text-slate-400 font-mono">Last 24 checks</span>
    </div>
  <% end %>
<% end %>
