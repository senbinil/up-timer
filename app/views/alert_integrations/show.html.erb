<div class="space-y-6">
  <%# ── Header ── %>
  <div class="space-y-2">
    <div class="flex items-center gap-1.5 text-xs text-slate-400 font-mono">
      <span>Infrastructure</span>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
      <span class="text-primary-container">Alert Integrations</span>
    </div>
    <h1 class="text-2xl md:text-[32px] font-semibold leading-10 tracking-[-0.01em] text-navy font-[Hanken_Grotesk]">Alert Integrations</h1>
    <p class="text-sm text-slate-400 max-w-2xl">Configure system notification endpoints, manage recipient groups, and define specific trigger conditions for automated fleet responses.</p>
  </div>

  <%# ── Two-Column Grid ── %>
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-6">
    <%# ═══════════════════════════════════════
       Column A: Email Notifications
       ═══════════════════════════════════════ %>
    <div class="card space-y-4">
      <div>
        <h2 class="text-base font-semibold text-primary-container font-[Hanken_Grotesk]">Email Notifications</h2>
        <p class="text-xs text-slate-400 mt-0.5">Manage active distribution lists for system alerts.</p>
      </div>

      <hr class="border-divider" />

      <%# Add Recipient Form %>
      <div class="space-y-2">
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Add New Recipient</p>
        <%= form_with model: @new_recipient, url: recipients_alert_integrations_path, class: "flex gap-2" do |f| %>
          <div class="relative flex-1">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </span>
            <%= f.email_field :email, required: true, placeholder: "admin@enterprise.ops", class: "input-field pl-10" %>
          </div>
          <%= f.button class: "btn btn-primary text-xs flex-shrink-0" do %>Add &rsaquo;<% end %>
        <% end %>
      </div>

      <%# Recipients List %>
      <div class="space-y-2">
        <p class="text-[10px] font-semibold uppercase tracking-[0.05em] text-slate-400 font-mono">Configured Recipients</p>
        <%= render "recipients_list" %>
      </div>

      <hr class="border-divider" />
      <p class="text-xs text-center text-primary-container font-medium">Bulk Manage Recipients</p>
    </div>

    <%# ═══════════════════════════════════════
       Column B: Alert Triggers
       ═══════════════════════════════════════ %>
    <div class="card space-y-0">
      <div class="flex items-center justify-between pb-3">
        <div>
          <h2 class="text-base font-semibold text-primary-container font-[Hanken_Grotesk]">Alert Triggers</h2>
          <p class="text-xs text-slate-400 mt-0.5">Define conditions that initiate notification sequences.</p>
        </div>
        <div class="flex items-center gap-2 text-xs text-slate-400 font-mono">
          <span>Select All</span>
          <div class="w-5 h-5 rounded border-2 border-[#e2e8f0]"></div>
        </div>
      </div>

      <div class="space-y-2">
        <%= render "triggers_list" %>
      </div>
    </div>
  </div>
</div>
