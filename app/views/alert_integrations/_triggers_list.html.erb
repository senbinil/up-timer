<%= turbo_frame_tag "triggers_list" do %>
  <% @triggers.each do |trigger| %>
    <div class="flex items-start gap-3 p-3 border border-border rounded-default">
      <%= button_to toggle_trigger_alert_integrations_path(trigger), method: :post, form: { data: { turbo_frame: "triggers_list" } }, class: "flex-shrink-0 mt-0.5" do %>
        <% if trigger.active? %>
          <div class="w-5 h-5 rounded bg-primary-container flex items-center justify-center">
            <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          </div>
        <% else %>
          <div class="w-5 h-5 rounded border-2 border-border"></div>
        <% end %>
      <% end %>

      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <h3 class="text-sm font-semibold text-navy"><%= trigger.name %></h3>
        </div>
        <p class="text-xs text-slate-400 leading-relaxed"><%= trigger.description %></p>
        <div class="flex items-center gap-2 mt-2">
          <%= button_to toggle_trigger_email_alert_integrations_path(trigger), method: :post, form: { data: { turbo_frame: "triggers_list" } }, class: "flex items-center gap-1.5 group" do %>
            <div class="w-5 h-5 rounded <%= trigger.email_notify? ? 'bg-primary-container flex items-center justify-center' : 'border-2 border-border' %>">
              <% if trigger.email_notify? %>
                <svg class="w-3 h-3 text-white mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <% end %>
            </div>
            <span class="text-[10px] text-slate-400 font-mono group-hover:text-navy transition-colors"><%= trigger.email_notify? ? 'Email on' : 'Email off' %></span>
          <% end %>
        </div>
        <% if current_account&.admin? && (log = trigger.last_action_log) %>
          <p class="text-[10px] text-slate-400 font-mono mt-2">
            <%= log.action.to_s.humanize %> by <%= log.account&.email || "system" %> <%= time_ago_in_words(log.created_at) %> ago
          </p>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @triggers.none? %>
    <p class="text-xs text-slate-400 py-8 text-center">No triggers configured.</p>
  <% end %>
<% end %>
