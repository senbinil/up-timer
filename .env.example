# Admin emails for the UpTimer platform.
# Comma-separated list — users registering with these emails will be granted admin role.
# All other new users default to "viewer".
#
# Example:
#   ADMIN_EMAILS=admin@example.com
#   ADMIN_EMAILS=alice@co.com,bob@co.com
ADMIN_EMAILS=

# Rails master key (required for production).
# Copy from config/master.key in the repo.
RAILS_MASTER_KEY=
